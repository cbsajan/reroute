"""
{{ route_name | capitalize }} CRUD Route

Full CRUD implementation for {{ resource_name }}.
"""

from reroute import RouteBase
from fastapi import Path, Query, Body
from fastapi.responses import JSONResponse
from typing import List, Dict, Any, Optional


class {{ class_name }}(RouteBase):
    """
    CRUD operations for {{ resource_name }}.

    Endpoints:
    - GET    {{ route_path }}        - List all {{ resource_name }}
    - GET    {{ route_path }}/{id}   - Get single {{ resource_name }}
    - POST   {{ route_path }}        - Create new {{ resource_name }}
    - PUT    {{ route_path }}/{id}   - Update {{ resource_name }}
    - DELETE {{ route_path }}/{id}   - Delete {{ resource_name }}

    Note: For individual item operations, create a separate route in a [id] subfolder.
    The [id] folder will be automatically converted to {id} path parameter.

    Alternative: Use _id subfolder for private/explicit routes (also supported).
    """

    def __init__(self):
        super().__init__()
        # In-memory database (replace with actual database)
        self.items: List[Dict[str, Any]] = []
        self.next_id = 1

    def before_request(self):
        """
        Authentication and validation hook.

        Add your authentication logic here:
        - Check API keys
        - Validate JWT tokens
        - Check permissions
        """
        # Example: Add authentication check
        # if not request.headers.get('Authorization'):
        #     return {"error": "Unauthorized"}, 401
        pass

    def get(self, limit: int = Query(10, description="Maximum results"), offset: int = Query(0, description="Skip results")) -> JSONResponse:
        """
        GET handler - List all {{ resource_name }}.

        Args:
            limit: Maximum number of results to return
            offset: Number of results to skip

        Returns:
            List of all items with pagination
        """
        # Apply pagination
        paginated = self.items[offset:offset + limit]
        return JSONResponse(content={
            "data": paginated,
            "count": len(self.items),
            "limit": limit,
            "offset": offset,
            "message": "{{ resource_name }} list retrieved successfully"
        })

    def post(self, data: Dict[str, Any] = Body(..., description="Item data to create")) -> JSONResponse:
        """
        POST handler - Create new {{ resource_name }}.

        Args:
            data: Request body data

        Returns:
            Created item with status
        """
        # Validate required fields
        required_fields = ["name"]  # TODO: Update with actual fields
        for field in required_fields:
            if field not in data:
                return JSONResponse(
                    content={
                        "error": f"Missing required field: {field}",
                        "required": required_fields
                    },
                    status_code=400
                )

        # Create new item
        new_item = {
            "id": self.next_id,
            **data
        }
        self.items.append(new_item)
        self.next_id += 1

        return JSONResponse(
            content={
                "data": new_item,
                "message": "{{ resource_name }} created successfully"
            },
            status_code=201
        )

    def put(self, id: int = Path(..., description="Item ID to update"), data: Dict[str, Any] = Body(..., description="Updated data")) -> JSONResponse:
        """
        PUT handler - Update existing {{ resource_name }}.

        Args:
            id: ID of item to update (from URL path)
            data: Update data (from request body)

        Returns:
            Updated item
        """
        item = self._find_by_id(id)
        if not item:
            return JSONResponse(
                content={
                    "error": "{{ resource_name }} not found",
                    "id": id
                },
                status_code=404
            )

        # Update item
        item.update(data)

        return JSONResponse(content={
            "data": item,
            "message": "{{ resource_name }} updated successfully"
        })

    def delete(self, id: int = Path(..., description="Item ID to delete")) -> JSONResponse:
        """
        DELETE handler - Delete {{ resource_name }}.

        Args:
            id: ID of item to delete (from URL path)

        Returns:
            Deletion confirmation
        """
        item = self._find_by_id(id)
        if not item:
            return JSONResponse(
                content={
                    "error": "{{ resource_name }} not found",
                    "id": id
                },
                status_code=404
            )

        # Delete item
        self.items = [i for i in self.items if i["id"] != id]

        return JSONResponse(content={
            "message": "{{ resource_name }} deleted successfully",
            "id": id
        })

    def _find_by_id(self, id: int) -> Optional[Dict[str, Any]]:
        """
        Helper method to find item by ID.

        Args:
            id: Item ID

        Returns:
            Item dict or None
        """
        for item in self.items:
            if item["id"] == id:
                return item
        return None

    def after_request(self, response):
        """
        Post-processing hook.

        Add custom headers, logging, metrics, etc.
        """
        # Example: Add custom header
        # response['X-Processed-By'] = 'REROUTE'
        return response

    def on_error(self, error: Exception) -> JSONResponse:
        """
        Error handling hook.

        Args:
            error: Exception that occurred

        Returns:
            Error response
        """
        return JSONResponse(content={
            "error": str(error),
            "type": type(error).__name__,
            "route": "{{ route_path }}",
            "resource": "{{ resource_name }}"
        })
